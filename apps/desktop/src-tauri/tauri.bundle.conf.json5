// Keeper —— 打包【专用】覆盖配置（sidecar onedir resources）。
//
// 只在打包这一步用：`pnpm tauri build --config src-tauri/tauri.bundle.conf.json5`
// （由 `mise run package` 自动带上）。tauri 会把它【合并】到 tauri.conf.json5 之上，
// 冲突字段以本文件为准，其余沿用基础配置。
//
// 为什么单独拆一个文件：resources 一旦写进基础配置，`mise run app`（dev）启动时
// tauri 就会强制要求 binaries/keeper-sidecar 存在，否则报错。
// 而 dev 下 sidecar 是 `mise run sidecar` 单独跑的、binaries/ 是空的。所以把
// 它单独隔离到这里，让本地 dev 零依赖。
{
  "$schema": "https://schema.tauri.app/config/2",
  "bundle": {
    // resources：把 PyInstaller onedir 整目录随应用分发（不用 externalBin——它只认单文件，
    // 承载不了 onedir 的「可执行 + _internal/ 库目录」布局）。键=源目录（相对 src-tauri/），
    // 值=落到包内 resource_dir 下的子路径，即 macOS 的 Contents/Resources/keeper-sidecar/。
    // 该目录由 `mise run bundle-sidecar`（冻结 onedir）+ `mise run stage-sidecar`（整目录落位）产出。
    // 安装后，Rust 壳用 app.path().resolve(.., Resource) 解析内层可执行、std::process 拉起（见 src/lib.rs）。
    "resources": { "binaries/keeper-sidecar": "keeper-sidecar" },

    // 打包时额外产出「更新包」制品：macOS 的 .app.tar.gz（+ .sig 签名）、Windows 的 -setup.exe（+ .sig）。
    // 这些是 updater 下载替换用的产物，与给用户首装的 .dmg/.exe 并存。
    // ⚠️ 一旦开启，`tauri build`（含 `mise run package`）会要求环境变量 TAURI_SIGNING_PRIVATE_KEY
    //（及 _PASSWORD）来签名，否则构建失败。本地打包前先 `mise run gen-update-keys` 生成密钥并 export。
    "createUpdaterArtifacts": true
  }
}
