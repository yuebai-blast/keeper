# Keeper 官网 Nginx 站点配置样例（美国机房，前置 Cloudflare 代理）。
# 拷到 /etc/nginx/sites-available/keeper-site 并按需改 server_name / root / 证书路径。
server {
    listen 80;
    server_name keeper.example.com;          # 改成你的域名
    return 301 https://$host$request_uri;     # 强制 HTTPS
}

server {
    listen 443 ssl http2;
    server_name keeper.example.com;           # 改成你的域名

    # 证书：Cloudflare Origin Certificate 或 Let's Encrypt（certbot）
    ssl_certificate     /etc/ssl/keeper/origin.pem;
    ssl_certificate_key /etc/ssl/keeper/origin.key;

    root /var/www/keeper-site;                 # 与 KEEPER_SITE_PATH 一致
    index index.html;

    gzip on;
    gzip_types text/css application/javascript image/svg+xml application/json;
    gzip_min_length 1024;

    # 带 hash 的静态资源长缓存
    location /assets/ {
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    # index.html 不缓存，保证发版即时可见
    location = /index.html {
        add_header Cache-Control "no-cache";
    }

    # 单页回退
    location / {
        try_files $uri $uri/ /index.html;
    }
}
